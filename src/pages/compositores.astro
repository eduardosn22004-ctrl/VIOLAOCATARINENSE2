---
import Layout from '../layouts/Layout.astro';

// --- BANCO DE DADOS DOS MÚSICOS ---
import { musicos } from '../data/musicos.js';


musicos.sort((a, b) => a.nome.localeCompare(b.nome));

// Função para gerar o texto de atuação
function obter_atuacao(eh_compositor, eh_violonista) {
    if (eh_compositor && eh_violonista) return "Compositor e Violonista";
    if (eh_compositor) return "Compositor";
    if (eh_violonista) return "Violonista";
    return "";
}
---

<Layout title="Violão Catarinense">
    
 <header class="flex flex-col items-center text-center pt-0 pb-6 mb-10">
    <div class="flex flex-col items-center text-center py-4 w-full">
        <h1 class="flex items-center justify-center gap-4 md:gap-6 text-4xl md:text-5xl font-bold text-red-700 font-['Cinzel'] uppercase tracking-tight">
            
            <div class="w-32 h-32 pt-15 md:w-56 md:h-56 shrink-0 flex items-center justify-center relative overflow-hidden">
                <svg viewBox="0 0 100 100" class="w-full h-full text-red-700 drop-shadow-md" xmlns="http://www.w3.org/2000/svg">
                    <g stroke="#e5e7eb" stroke-width="1.5" fill="none" stroke-linecap="round">
                        <path d="M 10,40 Q 50,25 90,40" class="animate-pulse" />
                        <path d="M 10,50 Q 50,35 90,50" class="animate-pulse" style="animation-delay: 0.5s;" />
                        <path d="M 10,60 Q 50,45 90,60" class="animate-pulse" style="animation-delay: 1s;" />
                    </g>

                    <g class="animate-note-1" fill="currentColor">
                        <path d="M45,65 C45,68.3 42.3,71 39,71 C35.7,71 33,68.3 33,65 C33,61.7 35.7,59 39,59 C41,59 42.7,60 43.8,61.4 L44.8,30 L65,25 L65,55 C65,58.3 62.3,61 59,61 C55.7,61 53,58.3 53,55 C53,51.7 55.7,49 59,49 C61,49 62.7,50 63.8,51.4 L63.8,31.5 L46.2,35.8 L45,65 Z"/>
                    </g>
                    
                    <g class="animate-note-2" fill="currentColor">
                        <path d="M25,80 C25,82.2 23.2,84 21,84 C18.8,84 17,82.2 17,80 C17,77.8 18.8,76 21,76 C22.3,76 23.5,76.7 24.2,77.6 L25,50 L35,47 L35,51.5 L26.5,54 L25,80 Z"/>
                    </g>
                    
                    <g class="animate-note-3" fill="currentColor">
                        <path d="M85,45 C85,47.2 83.2,49 81,49 C78.8,49 77,47.2 77,45 C77,42.8 78.8,41 81,41 C82.3,41 83.5,41.7 84.2,42.6 L85,15 L95,12 L95,16.5 L86.5,19 L85,45 Z"/>
                    </g>
                </svg>
            </div>

            <span class="relative after:absolute after:-bottom-2 after:left-0 after:w-full after:h-[2px] after:bg-red-700">
                Compositores e Violonistas
            </span>
        </h1>
        
        <div class="-mt-12 md:-mt-16 ml-32 md:ml-60 mb-10"> 
            <p class="text-xl text-stone-600 font-serif italic whitespace-nowrap">
                Artistas que contribuem para o repertório violonístico catarinense
            </p>
        </div>

        <div class="max-w-md w-full mx-auto px-4 mt-4">
            <div class="relative group">
                <input 
                        type="text" 
                        id="buscaCatalogo"
                        placeholder="Buscar por artista..." 
                        class="w-full px-6 py-3 rounded-full border-2 border-stone-200 focus:border-red-900 focus:outline-none transition-all duration-300 shadow-sm text-lg font-serif italic text-stone-700 bg-white"
                    />
                <div class="absolute right-5 top-1/2 -translate-y-1/2 text-stone-400 group-focus-within:text-red-700 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
            </div>
            <p id="noResults" class="hidden text-center mt-4 text-stone-500 italic">Nenhum compositor encontrado.</p>
        </div>
    </div>
</header>

<style>
    /* Animações das notas musicais subindo e desaparecendo suavemente */
    .animate-note-1 {
        animation: float-music 4s ease-in-out infinite;
    }
    .animate-note-2 {
        animation: float-music 5s ease-in-out infinite 1.5s;
        opacity: 0; /* Começa invisível até a animação rodar */
    }
    .animate-note-3 {
        animation: float-music 6s ease-in-out infinite 0.7s;
        opacity: 0;
    }

    @keyframes float-music {
        0% { transform: translateY(15px) rotate(-10deg) scale(0.8); opacity: 0; }
        20% { opacity: 0.8; }
        80% { opacity: 0.8; }
        100% { transform: translateY(-25px) rotate(15deg) scale(1.1); opacity: 0; }
    }
</style>

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 px-4" id="musicosContainer">
    {musicos.map((musico) => {
        const textoAtuacao = obter_atuacao(musico.eh_compositor, musico.eh_violonista);
        return (
        <div 
            class="musico-card group cursor-pointer transform transition-all hover:-translate-y-2" 
            onclick={`abrirModal('${musico.id}')`}
            data-nome={musico.nome.toLowerCase()}
        >
            <div class="overflow-hidden rounded-full shadow-lg aspect-square mb-4 relative bg-gray-100 border-4 border-white max-w-[180px] mx-auto">
                <img src={musico.foto} alt={musico.nome} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
            </div>
            
            <h3 class="text-xl font-bold text-center text-gray-800 group-hover:text-rose-700 transition-colors">
                {musico.nome}
            </h3>

            {/* AQUI ENTRA A FUNÇÃO DA ATUAÇÃO (Embaixo do nome, em cinza) */}
            {textoAtuacao && (
                <span class="block text-center text-gray-500 text-sm font-serif italic mt-1 group-hover:text-rose-500 transition-colors">
                    {textoAtuacao}
                </span>
            )}
            
            {/* Adicionei data-atuacao na div escondida para puxar pro Modal */}
            <div id={`data-${musico.id}`} class="hidden" data-nome={musico.nome} data-foto={musico.foto} data-galeria={JSON.stringify(musico.galeria)} data-atuacao={textoAtuacao}>
                <div class="data-bio" set:html={musico.bio}></div>
            </div>
        </div>
        );
    })}
</div>

<p id="noResultsCards" class="hidden text-center mt-12 text-stone-500 font-serif italic">
    Nenhum compositor encontrado com este nome.
</p>

    <div id="modal-overlay" class="fixed inset-0 z-50 hidden bg-black/30 backdrop-blur-sm flex items-center justify-center p-2 md:p-6 opacity-0 transition-opacity duration-300">
        
        <div class="bg-white rounded-3xl w-full max-w-5xl max-h-[92vh] overflow-y-auto shadow-2xl relative transform scale-95 transition-transform duration-300 custom-scrollbar" id="modal-content">
            
            <button onclick="fecharModal()" class="absolute top-6 right-6 bg-white/10 hover:bg-white/20 text-white rounded-full p-2.5 transition-colors z-30 border border-white/20">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6"><path d="M6 18L18 6M6 6l12 12" /></svg>
            </button>

            <div class="p-8 md:p-14 flex flex-col md:flex-row items-center gap-10 bg-stone-400 relative overflow-hidden">
                <div class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden border-8 border-stone-400 shadow-2xl flex-shrink-0 z-10">
                    <img id="modal-header-img" src="" alt="" class="w-full h-full object-cover" />
                </div>
                
                <div class="text-center md:text-left z-10">
                    <h2 id="modal-title" class="text-4xl md:text-6xl font-black text-red-800 leading-none tracking-tighter"></h2>
                    <span id="modal-atuacao" class="block text-xl text-stone-100 font-serif italic mt-3 drop-shadow-sm"></span>
                </div>
            </div>

            <div class="p-8 md:p-14">
                <div id="modal-bio" class="text-base text-gray-700 leading-relaxed space-y-6 text-justify">
                    </div>
            </div>

            <div id="gallery-section" class="bg-stone-100 p-8 md:p-14 border-t border-gray-100">
                <h3 class="text-center text-gray-400 uppercase tracking-[0.3em] text-xs font-black mb-10">Galeria de Imagens</h3>
                
                <div class="relative max-w-4xl mx-auto group/gallery">
                    <div class="aspect-video bg-stone-300 rounded-3xl overflow-hidden shadow-inner flex items-center justify-center relative border-8 border-white">
                        <img id="modal-gallery-img" src="" alt="" class="max-w-full max-h-full object-contain transition-opacity duration-300 opacity-100" />
                    </div>

                    <div class="absolute inset-0 flex items-center justify-between px-6 pointer-events-none">
                        <button onclick="mudarFoto(-1)" class="pointer-events-auto p-4 rounded-full bg-white/95 hover:bg-red-700 hover:text-white text-red-700 shadow-2xl transition-all opacity-0 group-hover/gallery:opacity-100">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-8 h-8"><path d="M15 19l-7-7 7-7" /></svg>
                        </button>
                        <button onclick="mudarFoto(1)" class="pointer-events-auto p-4 rounded-full bg-white/95 hover:bg-red-700 hover:text-white text-red-700 shadow-2xl transition-all opacity-0 group-hover/gallery:opacity-100">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-8 h-8"><path d="M9 5l7 7-7 7" /></svg>
                        </button>
                    </div>

                    <div id="gallery-counter" class="text-center mt-8 text-sm font-black text-gray-400 tracking-widest">
                        1 / 1
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 10px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #b91c1c; border-radius: 10px; }
    body.modal-open { overflow: hidden; }
</style>

<script is:inline>
// Lógica da Barra de Pesquisa
document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('searchInput');
    const cards = document.querySelectorAll('.musico-card');
    const noResultsCards = document.getElementById('noResultsCards');

    searchInput.addEventListener('input', () => {
        const termoBusca = searchInput.value.toLowerCase().trim();
        let encontrouQualquer = false;

        cards.forEach(card => {
            const nomeCompositor = card.getAttribute('data-nome');
            
            if (nomeCompositor.includes(termoBusca)) {
                card.style.display = 'block';
                encontrouQualquer = true;
            } else {
                card.style.display = 'none';
            }
        });

        // Mostra ou esconde a mensagem de "não encontrado" nos cards
        if (encontrouQualquer) {
            noResultsCards.classList.add('hidden');
        } else {
            noResultsCards.classList.remove('hidden');
        }
    });
});

    let galeriaAtual = [];
    let indiceAtual = 0;

    const modalOverlay = document.getElementById('modal-overlay');
    const modalContent = document.getElementById('modal-content');
    const modalTitle = document.getElementById('modal-title');
    const modalAtuacao = document.getElementById('modal-atuacao'); // Variável para a Atuação no Modal
    const headerImg = document.getElementById('modal-header-img');
    const galleryImg = document.getElementById('modal-gallery-img');
    const modalBio = document.getElementById('modal-bio');
    const gallerySection = document.getElementById('gallery-section');
    const galleryCounter = document.getElementById('gallery-counter');

    window.abrirModal = (id) => {
        const dataDiv = document.getElementById(`data-${id}`);
        if (!dataDiv) return;

        galeriaAtual = JSON.parse(dataDiv.getAttribute('data-galeria'));
        indiceAtual = 0;

        modalTitle.innerText = dataDiv.getAttribute('data-nome');
        // Puxa a atuação e injeta no modal
        modalAtuacao.innerText = dataDiv.getAttribute('data-atuacao');
        
        headerImg.src = dataDiv.getAttribute('data-foto');
        modalBio.innerHTML = dataDiv.querySelector('.data-bio').innerHTML;
        
        gallerySection.style.display = galeriaAtual.length > 0 ? 'block' : 'none';
        atualizarGaleria();

        modalOverlay.classList.remove('hidden');
        document.body.classList.add('modal-open');

        setTimeout(() => {
            modalOverlay.classList.remove('opacity-0');
            modalContent.classList.remove('scale-95');
            modalContent.classList.add('scale-100');
        }, 10);
    }

    window.mudarFoto = (direcao) => {
        galleryImg.style.opacity = '0';
        setTimeout(() => {
            indiceAtual = (indiceAtual + direcao + galeriaAtual.length) % galeriaAtual.length;
            atualizarGaleria();
            galleryImg.onload = () => galleryImg.style.opacity = '1';
        }, 200);
    }

    function atualizarGaleria() {
        galleryImg.src = galeriaAtual[indiceAtual];
        galleryCounter.innerText = `${indiceAtual + 1} / ${galeriaAtual.length}`;
    }

    window.fecharModal = () => {
        modalOverlay.classList.add('opacity-0');
        modalContent.classList.remove('scale-100');
        modalContent.classList.add('scale-95');
        setTimeout(() => {
            modalOverlay.classList.add('hidden');
            document.body.classList.remove('modal-open');
        }, 300);
    }

    modalOverlay.addEventListener('click', (e) => { if (e.target === modalOverlay) fecharModal(); });
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modalOverlay.classList.contains('hidden')) fecharModal();
        if (e.key === 'ArrowRight' && galeriaAtual.length > 1) mudarFoto(1);
        if (e.key === 'ArrowLeft' && galeriaAtual.length > 1) mudarFoto(-1);
    });
</script>
