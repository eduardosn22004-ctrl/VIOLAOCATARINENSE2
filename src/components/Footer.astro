---
const currentYear = new Date().getFullYear();
---

<footer class="relative left-1/2 right-1/2 ml-[-50vw] mr-[-50vw] w-screen mt-16 shadow-2xl z-40">
    
    <div class="absolute inset-0 bg-red-700 overflow-hidden pointer-events-none z-0">
        <img 
            src="/images/logo.png" 
            alt="Fundo Violão Footer" 
            class="absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-20 translate-y-10" 
        />
    </div>

    <div class="relative z-10 bg-black/60 border-t border-white/20 pt-12 pb-6 px-4">
        <div class="max-w-6xl mx-auto flex flex-col items-center justify-center gap-8">
            
            <h2 class="text-white text-2xl md:text-4xl font-['Cinzel'] font-bold tracking-wider text-center uppercase drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)]">
                Violão Catarinense
            </h2>

            <div class="w-full border-t border-white/10 pt-6 mt-4 flex items-center justify-center">
                <p class="text-white/50 text-[10px] md:text-xs tracking-widest uppercase text-center">
                    &copy; {currentYear} Violão Catarinense.
                </p>
            </div>
            
        </div>
    </div>
</footer>
