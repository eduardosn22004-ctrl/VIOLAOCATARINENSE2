---
// src/pages/index.astro
---

<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <title>Pierrot Game Music</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <script is:inline>
      // Função para detectar o melhor idioma
      function getTargetLanguage() {
        // Verifica se o usuário já escolheu um idioma manualmente antes (opcional)
        const savedLang = localStorage.getItem('preferred-lang');
        if (savedLang && (savedLang === 'pt' || savedLang === 'en')) {
          return savedLang;
        }

        // Pega o idioma do navegador (ex: "pt-BR" -> "pt")
        const browserLang = navigator.language.split('-')[0];
        return browserLang === 'en' ? 'en' : 'pt';
      }

      // Executa o redirecionamento
      const lang = getTargetLanguage();
      window.location.replace(`/${lang}/`);
    </script>

    <noscript>
      <meta http-equiv="refresh" content="0;url=/pt/" />
    </noscript>
    
    <link rel="canonical" href="https://pierrotgamemusic.com/pt/" />
  </head>
  <body class="bg-[#0f172a]">
    <div class="flex h-screen items-center justify-center">
      <div class="text-slate-400 animate-pulse font-sans">
        Loading... / Carregando...
      </div>
    </div>
  </body>
</html>
