<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="utf-8" />
  <title>Violão Catarinense</title>
  
  <script is:inline>
    // 1. Detecta o idioma do navegador
    // navigator.language geralmente retorna algo como 'pt-BR' ou 'en-US'
    const userLang = navigator.language || navigator.userLanguage;
    const isEnglish = userLang.startsWith('en');

    // 2. Define o destino (padrão é português)
    const targetPath = isEnglish ? '/en/' : '/pt/';

    // 3. Redireciona imediatamente sem deixar rastro no histórico de navegação
    window.location.replace(targetPath);
  </script>

  <link rel="canonical" href="https://violaocatarinense.com.br/pt/" />
  <noscript>
    <meta http-equiv="refresh" content="0;url=/pt/" />
  </noscript>
</head>
<body style="background: #111; color: #fff; font-family: sans-serif; display: flex; align-items: center; justify-content: center; height: 100vh;">
  <p>Carregando / Loading...</p>
</body>
</html>
