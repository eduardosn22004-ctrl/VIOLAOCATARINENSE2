---
import Layout from '../../layouts/Layout.astro';
import Markdown from '../../components/Markdown.astro';

const textoNovos = `
If you would like to contribute your compositions for solo guitar, duo, trio, or other instrumental settings to this project, 
please contact us at the email address above.
`;

const textoAtualizacao = `
Caso você seja um dos compositores ou violonistas já mencionado neste site e gostaria de atualizar o seu currículo, imagens, 
partes textuais entre outras informações, favor enviar mensagem para o endereço eletrônico supracitado.
`;

const textoPublico = `
If you are one of the composers or guitarists featured on this website and would like to update your biography, images, 
text, or any other information, please send a message to the email address mentioned above."
`;

const emailContato = "violaocatarinense@gmail.com";
---

<Layout title="Violão Catarinense">
    
    <div class="max-w-3xl mx-auto py-12 px-6 space-y-16">
        
        <div class="text-center">
            <h1 class="text-4xl font-bold text-red-700 mb-4">Participe Conosco</h1>
            <p class="text-xl text-stone-700">
                Join us in building and preserving the legacy of the guitar in Santa Catarina.
            </p>
        </div>

        <div class="bg-white/60 border border-rose-200 rounded-2xl p-8 text-center shadow-sm backdrop-blur-sm">
            <p class="text-lg font-medium text-stone-800 mb-4">
               Contact us at:
            </p>
            
            <a href={`mailto:${emailContato}`} class="group inline-flex items-center gap-3 text-2xl md:text-3xl font-bold text-red-800 hover:text-red-600 transition-colors break-all">
                
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 md:w-10 md:h-10 text-red-700 group-hover:text-red-500">
                    <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
                    <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
                </svg>
                
                {emailContato}
            </a>
        </div>

        <div class="space-y-12 divide-y divide-rose-200/50">
            
            <section class="pt-4">
                <h2 class="text-2xl font-bold text-red-700 mb-4">Interesse em Participar</h2>
                <div class="text-lg text-stone-800 leading-relaxed text-justify">
                    <Markdown content={textoNovos} />
                </div>
            </section>

            <section class="pt-10">
                <h2 class="text-2xl font-bold text-red-700 mb-4">Atualização de Perfil</h2>
                <div class="text-lg text-stone-800 leading-relaxed text-justify">
                    <Markdown content={textoAtualizacao} />
                </div>
            </section>

            <section class="pt-10">
                <h2 class="text-2xl font-bold text-red-700 mb-4">Público em Geral</h2>
                <div class="text-lg text-stone-800 leading-relaxed text-justify">
                    <Markdown content={textoPublico} />
                </div>
            </section>

        </div>

    </div>
</Layout>
