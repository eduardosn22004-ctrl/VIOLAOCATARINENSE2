---
// Importando o seu Layout (ajustei o caminho com '../../' pois ele estará dentro da pasta 'registros')
import Layout from '../../layouts/Layout.astro';

// Aqui você cadastra os seus registros. Fica muito mais fácil adicionar imagens novas depois!
const registrosPagina = [
    {
        src: '/images/decada20_foto1.jpg',
        legenda: 'Recital na Sociedade Harmonia Lyra, Joinville, 1928',
        fonte: 'Jornal A Notícia'
    },
    {
        src: '/images/decada20_foto2.jpg',
        legenda: 'Grupo de seresta em Florianópolis, ca. 1925',
        fonte: 'Arquivo Público Municipal'
    },
    {
        src: '/images/decada20_foto3.jpg',
        legenda: 'Violonista anônimo em estúdio',
        fonte: 'Coleção Particular'
    }
];
---

<Layout title="Década de 20 | Registros Históricos">
    
    <div class="max-w-6xl mx-auto py-16 px-6 space-y-24">

        {/* 1. TÍTULO PRINCIPAL ALINHADO À ESQUERDA */}
        <div class="border-l-4 border-red-700 pl-6">
            <h1 class="text-4xl md:text-5xl font-bold text-red-800 font-['Cinzel'] uppercase tracking-tight">
                Registros Históricos
            </h1>
            <p class="text-xl text-stone-600 mt-2 font-serif italic">
                A Trajetória do Violão em Santa Catarina na Década de 1920
            </p>
        </div>

        {/* 2. GALERIA DE FOTOS COM SOMBRAS E LEGENDAS */}
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {registrosPagina.map((registro) => (
                <div class="bg-white p-4 rounded-xl shadow-[0_8px_20px_rgba(0,0,0,0.08)] hover:shadow-[0_15px_30px_rgba(0,0,0,0.15)] transform transition hover:-translate-y-1 border border-stone-100">
                    <img 
                        src={registro.src} 
                        alt={registro.legenda} 
                        class="w-full h-64 object-cover rounded-md shadow-sm mb-4 bg-stone-200"
                    />
                    <div class="px-2">
                        <p class="text-lg font-medium text-stone-800 leading-snug">
                            {registro.legenda}
                        </p>
                        <p class="text-sm text-stone-500 font-serif italic mt-2">
                            Fonte: {registro.fonte}
                        </p>
                    </div>
                </div>
            ))}
        </section>

        {/* 3. SEÇÃO DE IMAGENS GRANDES (CARROSSEL) */}
        <section class="space-y-8 pt-8 border-t border-rose-200/50">
            
            {/* Título do Carrossel e Seta com Animação */}
            <div class="flex items-center gap-4 group cursor-pointer border-l-4 border-red-700 pl-6">
                <div>
                    <h2 class="text-3xl md:text-4xl font-bold text-red-800 font-['Cinzel'] uppercase tracking-tight">
                        Acervo em Destaque
                    </h2>
                    <p class="text-lg text-stone-600 mt-1 font-serif italic">
                        Deslize para o lado para explorar imagens exclusivas
                    </p>
                </div>
                {/* Seta animada: ela vai para o lado ao passar o mouse (group-hover:translate-x-3) */}
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-8 h-8 text-red-700 transition-transform duration-300 group-hover:translate-x-3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
            </div>

            {/* O Sistema de Rolagem (Carrossel Horizontal Nativo) */}
            <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory pb-8 pt-4 custom-scrollbar">
                
                {/* Item Grande 1 */}
                <div class="flex-none w-[90%] md:w-[75%] snap-center relative rounded-2xl overflow-hidden shadow-xl group">
                    <img 
                        src="/images/destaque20_1.jpg" 
                        alt="Apresentação histórica" 
                        class="w-full h-[400px] md:h-[550px] object-cover transition-transform duration-700 group-hover:scale-105 bg-stone-300"
                    />
                    {/* Gradiente escuro em cima da foto para a letra branca aparecer bem */}
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent flex flex-col justify-end p-8 md:p-12">
                        <p class="text-3xl md:text-4xl font-bold text-white font-['Cinzel'] drop-shadow-md">
                            Orquestra de Violões no Teatro
                        </p>
                        <p class="text-lg md:text-xl text-white/90 font-serif italic mt-2 drop-shadow">
                            Registro raríssimo de um concerto na capital. Fonte: Acervo Público do Estado.
                        </p>
                    </div>
                </div>

                {/* Item Grande 2 */}
                <div class="flex-none w-[90%] md:w-[75%] snap-center relative rounded-2xl overflow-hidden shadow-xl group">
                    <img 
                        src="/images/destaque20_2.jpg" 
                        alt="Outro violonista" 
                        class="w-full h-[400px] md:h-[550px] object-cover transition-transform duration-700 group-hover:scale-105 bg-stone-300"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent flex flex-col justify-end p-8 md:p-12">
                        <p class="text-3xl md:text-4xl font-bold text-white font-['Cinzel'] drop-shadow-md">
                            Roda de Choro Antiga
                        </p>
                        <p class="text-lg md:text-xl text-white/90 font-serif italic mt-2 drop-shadow">
                            Músicos reunidos na região central. Fonte: Jornal O Estado.
                        </p>
                    </div>
                </div>

            </div>
        </section>

    </div>
</Layout>

<style>
    /* Estilo sutil para a barra de rolagem do carrossel para não ficar feia no Windows */
    .custom-scrollbar::-webkit-scrollbar {
        height: 8px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f5f5f4;
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #b91c1c; 
        border-radius: 10px;
    }
</style>
